{
"compilerOptions": {
"target": "ES2022",
"module": "nodenext",
"moduleResolution": "nodenext",
"esModuleInterop": true,
"strict": true,
"skipLibCheck": true,
"forceConsistentCasingInFileNames": true,
"outDir": "./dist",
"rootDir": "./",
"declaration": true,
"allowImportingTsExtensions": true,
"noEmit": true,
"types": ["node"]
},
  "include": ["*.ts"],
  "exclude": ["node_modules", "dist"]
}
